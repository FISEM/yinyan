{
  "name": "@emmanuelcode/yinyan",
  "version": "1.0.0",
  "private": "false",
  "publishConfig": {
    "access": "public"
  },
  "description": "Handle errors as values in TypeScript. Balanced execution for sync and async flows.",
  "author": {
    "name": "Israel Emmanuel Matenly Forstal"
  },
  "keywords": [
    "typescript",
    "error-handling",
    "result-type",
    "safe-run",
    "async"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && bun build ./src/index.ts --outdir ./dist --minify --sourcemap && tsc -p tsconfig.json",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}